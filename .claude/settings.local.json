{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:nodemailer.com)",
      "Bash(cd:*)",
      "Bash(cd * && git *)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Edit(path:docs/**)",
      "Edit(path:scripts/**)",
      "Edit(path:src/**)",
      "Edit(path:test/**)",
      "Write(path:docs/**)",
      "Write(path:scripts/**)",
      "Write(path:src/**)",
      "Write(path:test/**)",
      "Bash(node:*)",
      "Bash(ls:*)",
      "Bash(gh pr:*)",
      "Bash(grep -l \"\\\\.execute\\\\|toEpub\" test/**/*.ts test/**/**/*.ts)",
      "Bash(where sonar-scanner *)",
      "Bash(npx sonar-scanner *)",
      "Bash(sonar *)",
      "Bash(tee sonar-secrets-output.txt)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx eslint --fix \"$CLAUDE_TOOL_OUTPUT_PATH\" 2>&1 || true"
          }
        ]
      }
    ]
  }
}
