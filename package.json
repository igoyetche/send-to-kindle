{
  "name": "paperboy",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "paperboy": "./dist/cli-entry.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "cli": "tsx src/cli-entry.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:email": "tsx scripts/test-email.ts",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "audit:ci": "npm audit --audit-level=high",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": "eslint --fix"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chokidar": "^4.0.3",
    "dotenv": "^17.3.1",
    "epub-gen-memory": "^1.1.2",
    "express": "^5.1.0",
    "marked": "^17.0.3",
    "nodemailer": "^8.0.4",
    "pino": "^9.6.0",
    "sanitize-html": "^2.14.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/nodemailer": "^7.0.0",
    "@types/sanitize-html": "^2.13.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.7"
  }
}
