# Required
# Kindle devices: comma-separated name:email pairs (up to 10)
# First device is the default when no device is specified
KINDLE_DEVICES=personal:your-kindle@kindle.com,work:work-kindle@kindle.com
SENDER_EMAIL=your-email@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# Optional
DEFAULT_AUTHOR=Claude
WATCH_FOLDER=/path/to/watch/folder
MCP_HTTP_PORT=3000
MCP_AUTH_TOKEN=your-secret-token
LOG_LEVEL=info

# Image downloading configuration (all optional with sensible defaults)
# IMAGE_FETCH_TIMEOUT_MS=15000      # Per-image download timeout (default: 15000ms)
# IMAGE_MAX_RETRIES=2               # Retry failed downloads (default: 2)
# IMAGE_MAX_CONCURRENCY=5           # Parallel downloads (default: 5)
# IMAGE_MAX_BYTES=5242880           # Max per-image (default: 5 MB)
# IMAGE_MAX_TOTAL_BYTES=104857600   # Max total payload (default: 100 MB)

# SonarCloud local scan token — generate at https://sonarcloud.io/account/security
SONAR_TOKEN=
